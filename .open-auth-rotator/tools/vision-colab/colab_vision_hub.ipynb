# ── CELL 2: Konfiguration ──────────────────────────────────
import os
AUTH_TOKEN = "sin-vision-2026-secure-token"
PORT = 8000

# ── CELL 3: Modell laden (Qwen3-VL 2B auf T4 GPU) ─────────
from transformers import AutoProcessor, Qwen2VLForConditionalGeneration
import torch

print("Loading Qwen3-VL 2B...")
model = Qwen2VLForConditionalGeneration.from_pretrained(
    "Qwen/Qwen2.5-VL-3B-Instruct",
    torch_dtype=torch.float16,
    device_map="auto",
    attn_implementation="flash_attention_2"
)
processor = AutoProcessor.from_pretrained("Qwen/Qwen2.5-VL-3B-Instruct")
print("Model loaded on:", model.device)

# ── CELL 4: FastAPI Server ─────────────────────────────────
from fastapi import FastAPI, UploadFile, File, Form, HTTPException
from PIL import Image
import io
import base64

app = FastAPI()

@app.get("/health")
async def health():
    return {"status": "ok", "model": "Qwen2.5-VL-3B", "device": str(model.device)}

@app.post("/analyze")
async def analyze_screen(
    file: UploadFile = File(...),
    prompt: str = Form(default="What is on this screen? Describe UI elements, errors, and what action should be taken next."),
    auth_token: str = Form(...)
):
    if auth_token != AUTH_TOKEN:
        raise HTTPException(status_code=401, detail="Unauthorized")

    image = Image.open(file.file).convert("RGB")
    if max(image.size) > 1024:
        image.thumbnail((1024, 1024))

    messages = [{
        "role": "user",
        "content": [
            {"type": "image", "image": image},
            {"type": "text", "text": prompt}
        ]
    }]

    text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = processor(text=[text], images=[image], return_tensors="pt").to(model.device)

    with torch.no_grad():
        output = model.generate(**inputs, max_new_tokens=500, temperature=0.1)

    response = processor.decode(output[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)
    return {"analysis": response.strip()}

@app.post("/analyze_video")
async def analyze_video(
    frames: list = Form(...),
    prompt: str = Form(default="Describe what happens in this video sequence."),
    auth_token: str = Form(...)
):
    if auth_token != AUTH_TOKEN:
        raise HTTPException(status_code=401, detail="Unauthorized")

    images = [Image.open(io.BytesIO(base64.b64decode(f))).convert("RGB") for f in frames]
    for img in images:
        if max(img.size) > 1024:
            img.thumbnail((1024, 1024))

    messages = [{
        "role": "user",
        "content": [
            *[{"type": "image", "image": img} for img in images],
            {"type": "text", "text": prompt}
        ]
    }]

    text = processor.apply_chat_template(messages, tokenize=False, add_generation_prompt=True)
    inputs = processor(text=[text], images=images, return_tensors="pt").to(model.device)

    with torch.no_grad():
        output = model.generate(**inputs, max_new_tokens=500, temperature=0.1)

    response = processor.decode(output[0][inputs.input_ids.shape[1]:], skip_special_tokens=True)
    return {"analysis": response.strip()}

# ── CELL 5: Cloudflare Tunnel starten ──────────────────────
import subprocess
import threading
import time
import re

def start_tunnel():
    proc = subprocess.Popen(
        ["cloudflared", "tunnel", "--url", f"http://127.0.0.1:{PORT}"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True
    )
    for line in iter(proc.stdout.readline, ''):
        match = re.search(r'https://[a-z0-9-]+\.trycloudflare\.com', line)
        if match:
            print(f"\n🔗 VISION HUB URL: {match.group(0)}")
            print(f"🔑 AUTH TOKEN: {AUTH_TOKEN}")
            print(f"\nCopy this URL to ~/.config/opencode/vision-colab-1.url (Account 1)")
            print(f"or ~/.config/opencode/vision-colab-2.url (Account 2)")
        print(line, end='')

threading.Thread(target=start_tunnel, daemon=True).start()
time.sleep(3)

# ── CELL 6: Server starten ─────────────────────────────────
import uvicorn
print(f"Starting FastAPI server on port {PORT}...")
uvicorn.run(app, host="127.0.0.1", port=PORT)
