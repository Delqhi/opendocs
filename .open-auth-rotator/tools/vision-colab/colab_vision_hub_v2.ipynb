import os
AUTH_TOKEN = "sin-vision-2026-secure-token"
PORT = 8000

# ── CELL 3: google-colab-ai Vision Endpoint ─────────────────
from google.colab import ai
from PIL import Image
import base64
import io

def analyze_image(image_path: str, prompt: str) -> str:
    """Analyze an image using google-colab-ai (Gemini Vision)."""
    image = Image.open(image_path).convert("RGB")
    if max(image.size) > 1024:
        image.thumbnail((1024, 1024))
    
    # google-colab-ai mit Bild — KEIN API KEY!
    response = ai.generate_text(
        prompt=prompt,
        images=[image]
    )
    return response.text

# Test
print("✅ google-colab-ai ready — NO API KEY NEEDED!")

# ── CELL 4: FastAPI Server ─────────────────────────────────
from fastapi import FastAPI, UploadFile, File, Form, HTTPException
import uvicorn

app = FastAPI()

@app.get("/health")
async def health():
    return {"status": "ok", "model": "gemini-via-google-colab-ai", "version": "v2"}

@app.post("/analyze")
async def analyze_screen(
    file: UploadFile = File(...),
    prompt: str = Form(default="What is on this screen? Describe UI elements, errors, and what action should be taken next."),
    auth_token: str = Form(...)
):
    if auth_token != AUTH_TOKEN:
        raise HTTPException(status_code=401, detail="Unauthorized")
    
    # Save uploaded file temporarily
    import tempfile
    with tempfile.NamedTemporaryFile(suffix=".png", delete=False) as tmp:
        tmp.write(await file.read())
        tmp_path = tmp.name
    
    try:
        result = analyze_image(tmp_path, prompt)
        return {"analysis": result}
    finally:
        os.unlink(tmp_path)

@app.post("/analyze_batch")
async def analyze_batch(
    files: list[UploadFile] = File(...),
    prompt: str = Form(default="Describe what happens in this sequence."),
    auth_token: str = Form(...)
):
    if auth_token != AUTH_TOKEN:
        raise HTTPException(status_code=401, detail="Unauthorized")
    
    import tempfile
    results = []
    for f in files:
        with tempfile.NamedTemporaryFile(suffix=".png", delete=False) as tmp:
            tmp.write(await f.read())
            tmp_path = tmp.name
        try:
            result = analyze_image(tmp_path, prompt)
            results.append(result)
        finally:
            os.unlink(tmp_path)
    
    return {"analyses": results}

# ── CELL 5: Cloudflare Tunnel starten ──────────────────────
import subprocess
import threading
import time
import re

def start_tunnel():
    proc = subprocess.Popen(
        ["cloudflared", "tunnel", "--url", f"http://127.0.0.1:{PORT}"],
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True
    )
    for line in iter(proc.stdout.readline, ''):
        match = re.search(r'https://[a-z0-9-]+\.trycloudflare\.com', line)
        if match:
            print(f"\n🔗 VISION HUB URL (v2): {match.group(0)}")
            print(f"🔑 AUTH TOKEN: {AUTH_TOKEN}")
            print(f"🤖 MODEL: Gemini via google-colab-ai (NO API KEY)")
            print(f"\nCopy this URL to ~/.config/opencode/vision-colab-1.url (Account 1)")
            print(f"or ~/.config/opencode/vision-colab-2.url (Account 2)")
        print(line, end='')

threading.Thread(target=start_tunnel, daemon=True).start()
time.sleep(3)

